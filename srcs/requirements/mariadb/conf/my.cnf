[mysqld]

# CRITICAL: Listen on all interfaces, not just localhost
# Without this, WordPress container can't reach MariaDB
# because they're on different network namespaces
bind-address = 0.0.0.0

# Data directory
datadir = /var/lib/mysql

# Socket file location
socket = /run/mysqld/mysqld.sock

# Port
port = 3306

# Don't resolve hostnames — speeds up connections
skip-name-resolve = 1

# Logging (useful for debugging during eval)
general_log = 0
log_error = /var/log/mysql/error.log