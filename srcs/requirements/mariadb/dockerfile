FROM alpine:3.18

# Install MariaDB — no pulling mariadb:latest from DockerHub!
RUN apk update && apk add --no-cache \
    mariadb \
    mariadb-client

# Create the data directory and set ownership
# mysqld needs to own this or it won't start
RUN mkdir -p /var/lib/mysql \
    && chown -R mysql:mysql /var/lib/mysql

# Create run directory for the socket/pid file
RUN mkdir -p /run/mysqld \
    && chown -R mysql:mysql /run/mysqld

# Copy custom MariaDB config
COPY conf/my.cnf /etc/my.cnf.d/inception.cnf

# Copy and set permissions on entrypoint
COPY tools/db-setup.sh /usr/local/bin/db-setup.sh
RUN chmod +x /usr/local/bin/db-setup.sh

# MariaDB listens on 3306 — only exposed to internal Docker network
EXPOSE 3306

ENTRYPOINT ["/usr/local/bin/db-setup.sh"]